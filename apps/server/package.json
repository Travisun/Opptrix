{
  "name": "@inno-a-stock/server",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && concurrently -k -n tsc,api \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node scripts/dev.mjs\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "mcp": "npm run build -w @inno-a-stock/agent && node ../../packages/agent/dist/mcp/stdio-entry.js"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@inno-a-stock/agent": "*",
    "@inno-a-stock/research-hub": "*",
    "@inno-a-stock/stock-eval": "*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
