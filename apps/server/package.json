{
  "name": "@opptrix/server",
  "version": "0.4.0",
  "private": true,
  "description": "Opptrix 本地 API 服务（Fastify + Agent 投研引擎）",
  "homepage": "https://www.opptrix.org",
  "license": "Apache-2.0",
  "author": "Opptrix contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Travisun/Opptrix.git",
    "directory": "apps/server"
  },
  "bugs": {
    "url": "https://github.com/Travisun/Opptrix/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "npm run build && concurrently -k -n tsc,api \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node scripts/dev.mjs\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "mcp": "npm run build -w @opptrix/agent && node ../../packages/agent/dist/mcp/stdio-entry.js"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@opptrix/agent": "*",
    "@opptrix/article-enrichment": "*",
    "@opptrix/local-inference": "*",
    "@opptrix/market-data-store": "*",
    "@opptrix/news-feed": "*",
    "@opptrix/research-hub": "*",
    "@opptrix/search-hub": "*",
    "@opptrix/stock-eval": "*",
    "@opptrix/user-store": "*",
    "fastify": "^5.2.0",
    "ffmpeg-static": "^5.3.0",
    "node-llama-cpp": "^3.19.0",
    "nodejs-whisper": "^0.3.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
