{
  "name": "@opptrix/server",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && concurrently -k -n tsc,api \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node scripts/dev.mjs\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "mcp": "npm run build -w @opptrix/agent && node ../../packages/agent/dist/mcp/stdio-entry.js"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@opptrix/agent": "*",
    "@opptrix/news-feed": "*",
    "@opptrix/research-hub": "*",
    "@opptrix/stock-eval": "*",
    "@opptrix/user-store": "*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
