{
  "name": "@opptrix/desktop",
  "version": "0.6.0-dev.27",
  "private": true,
  "description": "Opptrix 桌面端：Electron 壳 + 本地投研 API，支持自动更新与离线数据",
  "homepage": "https://www.opptrix.org",
  "author": {
    "name": "Opptrix contributors",
    "email": "imsorich@foxmail.com",
    "url": "https://www.opptrix.org"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Travisun/Opptrix.git",
    "directory": "apps/desktop"
  },
  "bugs": {
    "url": "https://github.com/Travisun/Opptrix/issues"
  },
  "keywords": [
    "opptrix",
    "desktop",
    "electron",
    "investment-research",
    "stock",
    "finance"
  ],
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/prebuild.mjs && electron-builder --config.npmRebuild=false",
    "build:dir": "OPPTRIX_MAC_UNSIGNED=1 node scripts/prebuild.mjs && electron-builder --dir --config.npmRebuild=false -c.mac.hardenedRuntime=false",
    "build:local": "OPPTRIX_MAC_UNSIGNED=1 CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/prebuild.mjs && electron-builder --dir --config.npmRebuild=false -c.mac.hardenedRuntime=false",
    "build:package": "node scripts/prebuild.mjs && node scripts/build-package.mjs",
    "build:package:mac-arm64": "node scripts/prebuild.mjs && node scripts/build-package.mjs --mac --arm64",
    "build:package:mac-x64": "node scripts/prebuild.mjs && node scripts/build-package.mjs --mac --x64",
    "build:publish": "node scripts/prebuild.mjs && node scripts/build-package.mjs --publish always",
    "build:publish:mac-arm64": "node scripts/prebuild.mjs && node scripts/build-package.mjs --mac --arm64 --publish always",
    "build:publish:mac-x64": "node scripts/prebuild.mjs && node scripts/build-package.mjs --mac --x64 --publish always",
    "verify:release-metadata-policy": "node scripts/verify-release-metadata-policy.mjs",
    "verify:packaged-updater": "node scripts/verify-packaged-updater.mjs",
    "verify:r2-credentials": "node scripts/verify-r2-credentials.mjs",
    "verify:runtime": "node scripts/verify-runtime.mjs"
  },
  "build": {
    "appId": "com.cuishushu.app.opptrix.desktop",
    "productName": "Opptrix",
    "copyright": "Copyright © 2026 Opptrix contributors",
    "electronVersion": "35.7.5",
    "afterPack": "./scripts/after-pack-adhoc.cjs",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "detectUpdateChannel": false,
    "protocols": [
      {
        "name": "Opptrix Link",
        "schemes": [
          "opptrix"
        ]
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://update.opptrix.org/desktop/",
        "channel": "latest"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "build/icons/**/*",
      "build/updater-deps/**/*",
      "!node_modules/**/*",
      "node_modules/node-llama-cpp/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-llama-cpp/**",
      "**/build/updater-deps/**"
    ],
    "icon": "build/icons/logo-app.png",
    "extraResources": [
      {
        "from": "runtime-stage",
        "to": "runtime-stage",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.inherit.plist",
      "darkModeSupport": true,
      "extendInfo": {
        "CFBundleDisplayName": "Opptrix",
        "CFBundleName": "Opptrix",
        "CFBundleSpokenName": "Opptrix",
        "CFBundleGetInfoString": "Opptrix — 全球多市场投研数据助手",
        "NSHumanReadableCopyright": "Copyright © 2026 Opptrix contributors",
        "NSUserNotificationUsageDescription": "Opptrix 需要在后台向你发送版本更新、任务完成等本地通知。",
        "NSHighResolutionCapable": true,
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.finance",
        "NSSupportsAutomaticTermination": false,
        "NSSupportsSuddenTermination": false,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "安装 Opptrix ${version}",
      "icon": "build/icons/icon.icns",
      "iconSize": 96,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "legalTrademarks": "Opptrix",
      "artifactName": "${productName}-${version}-Windows.${ext}",
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "publisherName": "Opptrix"
      }
    },
    "nsis": {
      "shortcutName": "Opptrix",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "deb": {
      "packageName": "opptrix"
    },
    "linux": {
      "icon": "build/icons/linux",
      "category": "Office;Finance",
      "synopsis": "面向个人投资者的多市场投研助手",
      "description": "Opptrix 桌面端：自然语言提问即可查看行情、新闻与研报摘要，数据默认保存在本机。",
      "artifactName": "${productName}-${version}-Linux.${ext}",
      "executableName": "opptrix",
      "desktop": {
        "Name": "Opptrix",
        "Comment": "面向个人投资者的多市场投研助手",
        "GenericName": "投研助手",
        "Keywords": "股票;投研;全球;美股;港股;加密货币;财经;",
        "StartupWMClass": "Opptrix",
        "MimeType": "x-scheme-handler/opptrix;"
      },
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "to-ico": "^1.1.5"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "node-llama-cpp": "^3.19.0"
  }
}
