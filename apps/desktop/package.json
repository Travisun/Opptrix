{
  "name": "@opptrix/desktop",
  "version": "0.6.0-dev.11",
  "private": true,
  "description": "Opptrix cross-platform desktop shell (Electron + Node sidecar)",
  "homepage": "https://github.com/Travisun/Opptrix",
  "author": {
    "name": "催书书",
    "email": "imsorich@foxmail.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Travisun/Opptrix.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/prebuild.mjs && electron-builder --config.npmRebuild=false",
    "build:dir": "OPPTRIX_MAC_UNSIGNED=1 node scripts/prebuild.mjs && electron-builder --dir --config.npmRebuild=false -c.mac.hardenedRuntime=false -c.mac.identity=-",
    "build:local": "OPPTRIX_MAC_UNSIGNED=1 CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/prebuild.mjs && electron-builder --dir --config.npmRebuild=false -c.mac.hardenedRuntime=false -c.mac.identity=-",
    "build:package": "node scripts/prebuild.mjs && node scripts/build-package.mjs",
    "build:package:mac-arm64": "node scripts/prebuild.mjs && node scripts/build-package.mjs --mac --arm64",
    "build:package:mac-x64": "node scripts/prebuild.mjs && node scripts/build-package.mjs --mac --x64",
    "build:publish": "node scripts/prebuild.mjs && electron-builder --config.npmRebuild=false --publish always",
    "build:publish:mac-arm64": "node scripts/prebuild.mjs && electron-builder --config.npmRebuild=false --mac --arm64 --publish always",
    "build:publish:mac-x64": "node scripts/prebuild.mjs && electron-builder --config.npmRebuild=false --mac --x64 --publish always",
    "verify:runtime": "node scripts/verify-runtime.mjs"
  },
  "build": {
    "appId": "com.cuishushu.app.opptrix.desktop",
    "productName": "Opptrix",
    "copyright": "Copyright © 2026 催书书",
    "electronVersion": "35.7.5",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "protocols": [
      {
        "name": "Opptrix Link",
        "schemes": [
          "opptrix"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Travisun",
        "repo": "Opptrix",
        "vPrefixedTagName": false
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "build/icons/**/*",
      "build/updater-deps/node_modules/**/*",
      "!node_modules/**/*",
      "node_modules/node-llama-cpp/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-llama-cpp/**",
      "**/build/updater-deps/**"
    ],
    "icon": "build/icons/logo-app.png",
    "extraResources": [
      {
        "from": "runtime-stage",
        "to": "runtime-stage",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icons/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.inherit.plist",
      "darkModeSupport": true,
      "extendInfo": {
        "CFBundleDisplayName": "Opptrix",
        "CFBundleName": "Opptrix",
        "CFBundleSpokenName": "Opptrix",
        "CFBundleGetInfoString": "Opptrix 你的A股投研助手",
        "NSHumanReadableCopyright": "Copyright © 2026 催书书",
        "NSUserNotificationUsageDescription": "Opptrix 需要在后台向你发送版本更新、任务完成等本地通知。",
        "NSHighResolutionCapable": true,
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.finance",
        "NSSupportsAutomaticTermination": false,
        "NSSupportsSuddenTermination": false,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "安装 Opptrix ${version}",
      "icon": "build/icons/icon.icns",
      "iconSize": 96,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "legalTrademarks": "Opptrix",
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "publisherName": "Opptrix"
      }
    },
    "nsis": {
      "shortcutName": "Opptrix",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "deb": {
      "packageName": "opptrix"
    },
    "linux": {
      "icon": "build/icons/linux",
      "category": "Office;Finance",
      "synopsis": "你的A股投研助手",
      "description": "Opptrix 桌面端：聊天投研、个股研究、新闻订阅与本地数据分析。",
      "artifactName": "${productName}-${version}.${ext}",
      "executableName": "opptrix",
      "desktop": {
        "Name": "Opptrix",
        "Comment": "你的A股投研助手",
        "GenericName": "投研助手",
        "Keywords": "股票;投研;A股;财经;",
        "StartupWMClass": "Opptrix",
        "MimeType": "x-scheme-handler/opptrix;"
      },
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "to-ico": "^1.1.5"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "node-llama-cpp": "^3.19.0"
  }
}
