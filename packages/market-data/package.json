{
  "name": "@opptrix/market-data-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "test -f dist/index.d.ts || rm -f tsconfig.tsbuildinfo; tsc -b tsconfig.json",
    "sync": "npm run build && node dist/cli/sync.js"
  },
  "dependencies": {
    "@dsnp/parquetjs": "^1.8.8",
    "@opptrix/a-stock-layer": "*",
    "@opptrix/shared": "*",
    "@opptrix/stock-eval": "*",
    "@opptrix/user-store": "*",
    "better-sqlite3": "^11.7.0",
    "parquet-wasm": "^0.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
}
