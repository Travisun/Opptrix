# Opptrix 启动环境变量示例
# 用法：cp example/startup/env.example .env  然后填入密钥

# ── API 服务（内部端口，Web 开发时由 Vite 代理 /api）──
STOCK_RESEARCH_PORT=8711
STOCK_RESEARCH_HOST=127.0.0.1

# ── Web 前端（开发 / 预览）──
WEB_PORT=5173

# ── LLM（OpenAI 兼容接口，对话功能需要）──
LLM_PROVIDER=DeepSeek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com

# ── 默认投研参数 ──
DEFAULT_SCORECARD=综合评估
DEFAULT_TOP_N=20

# ── 可选：Tushare Pro（也可在设置 → 基础数据 中配置）──
# TUSHARE_TOKEN=

# ── 可选：独立用户数据目录（试用 example 配置时推荐）──
# OPPTRIX_DATA_DIR=/path/to/your/opptrix-data

# ── 可选：桌面壳层标记（一般由 Electron 自动设置）──
# OPPTRIX_DESKTOP=1

# ── 可选：Vite 开发代理 ──
# VITE_API_BASE=/api
