# Opptrix — environment variables (copy to .env)
# 更完整的启动说明与可选变量见 example/startup/env.example

# Server (API backend — internal, proxied by Vite)
STOCK_RESEARCH_PORT=8711
STOCK_RESEARCH_HOST=127.0.0.1

# Web (user-facing)
# Dev/preview: http://127.0.0.1:5173
WEB_PORT=5173

# LLM (DeepSeek / OpenAI-compatible)
LLM_PROVIDER=DeepSeek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com

# Defaults
DEFAULT_SCORECARD=综合评估
DEFAULT_TOP_N=20

# Optional: Vite dev proxy target (client-ui only)
# VITE_API_BASE=/api
